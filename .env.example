# ─────────────────────────────────────────────────────────────
# Mnemo environment configuration
# Copy this file to `.env.local` and fill in values.
# The app RUNS WITH NO KEYS using mock providers — keys only
# unlock live data and real AI.
# ─────────────────────────────────────────────────────────────

# ── Supabase (auth + database + realtime) ──────────────────────
# Create a free project at https://supabase.com, then find these
# under Project Settings → API. Without these, auth/persistence
# are disabled but the 3D landing + mock feed/markets still work.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only key (NEVER expose to the browser). Used by API routes.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI provider (insights & predictions) ───────────────────────
# Options: "mock" (default, no key), "gemini", "openai".
AI_PROVIDER=mock
# Google Gemini — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# OpenAI (alternative) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Market data provider ───────────────────────────────────────
# Options: "mock" (default, no key), "finnhub".
MARKET_PROVIDER=mock
# Finnhub free tier — https://finnhub.io/register
FINNHUB_API_KEY=

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Starting virtual cash for new paper-trading accounts (USD).
NEXT_PUBLIC_PAPER_STARTING_CASH=100000
